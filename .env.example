# Copy to .env.local for local `vercel dev`, or set these in Vercel dashboard.

# Restrict CORS to your GitHub Pages origin in production, e.g.
# https://<your-username>.github.io
ALLOWED_ORIGIN=*

# Claude API key (https://console.anthropic.com).
# - Enables Claude-powered reranking in "smart search" (without it, the
#   heuristic ranking is used).
# - REQUIRED for the Resume (/api/resume) analysis tab — it returns 503 if unset.
ANTHROPIC_API_KEY=

# Model for the resume analysis. Default is the cheap claude-haiku-4-5 (to
# stretch a small spend cap). Set to claude-opus-4-8 for the best quality.
ANALYSIS_MODEL=claude-haiku-4-5

# Optional access code that protects the paid /api/resume endpoint. If set,
# requests must send a matching `x-access-code` header (the UI prompts for it
# and stores it). Leave empty to keep the endpoint open. Recommended for a
# publicly reachable deploy so strangers can't burn your API budget.
ANALYSIS_ACCESS_CODE=
