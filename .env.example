# Copy to .env.local for local `vercel dev`, or set these in Vercel dashboard.

# Restrict CORS to your GitHub Pages origin in production, e.g.
# https://<your-username>.github.io
ALLOWED_ORIGIN=*

# Claude API key (https://console.anthropic.com).
# - Enables Claude-powered reranking in "smart search" (without it, the
#   heuristic ranking is used).
# - REQUIRED for the Resume (/api/resume) and LinkedIn (/api/linkedin)
#   analysis tabs — those return 503 if it's unset.
ANTHROPIC_API_KEY=

# Optional: free Jooble API key (https://jooble.org/api/about).
# Enables the Jooble meta-aggregator source (widest coverage). Without it the
# Jooble source is simply skipped.
JOOBLE_API_KEY=

# Optional + risky: enable the LinkedIn source (off by default).
# Scraping LinkedIn violates its ToS — enable at your own responsibility.
ENABLE_LINKEDIN=false
